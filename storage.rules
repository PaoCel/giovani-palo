rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function userDocPath(uid) {
      return /databases/(default)/documents/users/$(uid);
    }

    function registrationDocPath(stakeId, activityId, registrationId) {
      return /databases/(default)/documents/stakes/$(stakeId)/activities/$(activityId)/registrations/$(registrationId);
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function currentUserExists() {
      return isSignedIn() && firestore.exists(userDocPath(request.auth.uid));
    }

    function currentUser() {
      return firestore.get(userDocPath(request.auth.uid)).data;
    }

    function isAdminRole(role) {
      return role == 'admin' || role == 'super_admin';
    }

    function isStakeAdmin(stakeId) {
      return currentUserExists()
        && isAdminRole(currentUser().role)
        && (
          currentUser().role == 'super_admin'
          || currentUser().stakeId == stakeId
        );
    }

    function isRegistrationOwner(stakeId, activityId, registrationId) {
      return isSignedIn()
        && firestore.exists(registrationDocPath(stakeId, activityId, registrationId))
        && (
          firestore.get(registrationDocPath(stakeId, activityId, registrationId)).data.userId == request.auth.uid
          || firestore.get(registrationDocPath(stakeId, activityId, registrationId)).data.anonymousUid == request.auth.uid
        );
    }

    match /public/stakes/{stakeId}/activities/{activityId}/{fileName=**} {
      allow read: if true;
      allow write: if isStakeAdmin(stakeId);
    }

    match /public/stakes/{stakeId}/settings/{assetKind}/{fileName=**} {
      allow read: if true;
      allow write: if isStakeAdmin(stakeId);
    }

    match /public/stakes/{stakeId}/drafts/{uid}/{fileName=**} {
      allow read: if isStakeAdmin(stakeId);
      allow write: if isStakeAdmin(stakeId);
    }

    match /protected/stakes/{stakeId}/activities/{activityId}/parent-consents/{registrationId}/{fileName=**} {
      allow read: if isStakeAdmin(stakeId) || isRegistrationOwner(stakeId, activityId, registrationId);
      allow write: if isStakeAdmin(stakeId) || isRegistrationOwner(stakeId, activityId, registrationId);
    }

    match /protected/stakes/{stakeId}/activities/{activityId}/signatures/{registrationId}/{fileName=**} {
      allow read: if isStakeAdmin(stakeId) || isRegistrationOwner(stakeId, activityId, registrationId);
      allow write: if isStakeAdmin(stakeId) || isRegistrationOwner(stakeId, activityId, registrationId);
    }

    match /protected/stakes/{stakeId}/activities/{activityId}/parent-ids/{registrationId}/{fileName=**} {
      allow read: if isStakeAdmin(stakeId) || isRegistrationOwner(stakeId, activityId, registrationId);
      allow write: if isStakeAdmin(stakeId) || isRegistrationOwner(stakeId, activityId, registrationId);
    }

    // PDF di audit dell'autorizzazione genitoriale: scritti solo da Cloud Functions
    // (Admin SDK bypassa queste rules), letti solo da admin di stake.
    // L'utente / genitore non deve poter leggere il PDF dal browser.
    match /protected/stakes/{stakeId}/activities/{activityId}/parent-authorization-pdfs/{registrationId}/{fileName=**} {
      allow read: if isStakeAdmin(stakeId);
      allow write: if false;
    }

    // Firme genitore raccolte tramite magic-link (separate da quelle MVP esistenti
    // per evitare collisioni con consenti gia' caricati dall'utente loggato).
    match /protected/stakes/{stakeId}/activities/{activityId}/parent-authorization-signatures/{registrationId}/{fileName=**} {
      allow read: if isStakeAdmin(stakeId);
      allow write: if false;
    }

    // Galleria foto/video: accesso aperto a chiunque sia loggato. Niente
    // piu' codice galleria richiesto (vedi firestore.rules /galleries/...
    // per il commento di contesto).
    match /protected/stakes/{stakeId}/galleries/{galleryId}/media/{mediaId}/{fileName=**} {
      allow read: if isSignedIn();
      allow write: if isStakeAdmin(stakeId);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
